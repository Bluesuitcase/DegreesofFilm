{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "docs",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000", "--directory", "docs"],
      "port": 8000
    },
    {
      "name": "curation",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "app:app", "--app-dir", "curation", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "worker",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "dev", "--config", "server/wrangler.toml", "--port", "8787"],
      "port": 8787
    }
  ]
}
